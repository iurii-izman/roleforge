# Copy this file to .env and fill only the values you actually use.
# Never commit real secrets.
# Keyring-first secret handling is preferred for local development; in hosted runtime,
# these values are injected from the provider's secret store as environment variables.

# AI providers (MVP uses one primary provider; see PRIMARY_AI_PROVIDER)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# GitHub / automation (prefer: gh auth; project scope via gh auth refresh -s project)
GITHUB_TOKEN=
# Linear: prefer keyring domain=linear key=api_key (see docs/bootstrap-access.md)
LINEAR_API_KEY=

# Gmail / Google
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_INTAKE_LABEL=
GMAIL_POLL_INTERVAL_MINUTES=15

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_CHAT_ID=
# Optional webhook mode (if used by hosting/runtime)
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# Storage / runtime
DATABASE_URL=
PRIMARY_AI_PROVIDER=  # openai | anthropic
ROLEFORGE_SECRET_SERVICE=roleforge

# Local / hosted application defaults
APP_ENV=development
APP_PORT=3000
LOG_LEVEL=INFO

